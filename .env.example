# JobHunter AI — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Database & Paths ─────────────────────────────────────────────────────────
DATABASE_URL=./data/applications.db
OUTPUT_DIR=./outputs
LATEX_COMPILER=pdflatex

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_RATE_LIMIT_SECONDS=5
SCRAPER_TIMEOUT_SECONDS=30
MAX_PARALLEL_SCRAPES=5

# ── LLM ──────────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TEMPERATURE=0.3
MAX_PARALLEL_TAILORS=3

# ── Scoring Thresholds ────────────────────────────────────────────────────────
APPLY_THRESHOLD=60
REVIEW_THRESHOLD=45

# ── Scheduler ────────────────────────────────────────────────────────────────
DAILY_BATCH_TIME=08:00
TIMEZONE=America/Toronto

# ── Frontend ─────────────────────────────────────────────────────────────────
# Used by Next.js API routes to locate the Python backend root
BACKEND_ROOT=..
NEXT_PUBLIC_WS_URL=ws://localhost:3001
